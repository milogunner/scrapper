{
  "name": "scrapper",
  "version": "1.2.0",
  "description": "OBI / Modivo scraper do WooCommerce CSV",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "scrape": "node scraper.js",
    "postinstall": "node -e \"if(!process.env.PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD && !process.env.CI){require('child_process').execSync('npx playwright install chromium --with-deps',{stdio:'inherit'})}\"",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "dist": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 electron-builder --win",
    "dist:win": "set PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@antiadmin/anticaptchaofficial": "^1.0.55",
    "csv-writer": "^1.6.0",
    "express": "^5.2.1",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "pl.scrapper.app",
    "productName": "Scrapper",
    "copyright": "Copyright © 2025",
    "asar": false,
    "files": [
      "electron/**/*",
      "server.js",
      "scrapers/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/.cache",
      "!**/*.md",
      "!downloads/**",
      "!logs/**",
      "!*.csv",
      "!*.zip"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Scrapper"
    },
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron"
    }
  }
}
